# ── Credentials (only required for live trading; leave blank for paper trading) ──

# Polymarket
POLY_PRIVATE_KEY=               # Polygon EOA private key (funded with USDC.e)
POLY_FUNDER=                    # Optional: separate funder wallet

# Hyperliquid
HL_ADDRESS=                     # Hyperliquid main wallet address
HL_SECRET_KEY=                  # Hyperliquid API wallet private key (NOT the master key)

# ── Optional ─────────────────────────────────────────────────────────────────

# Telegram alerts (leave blank to disable)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# API server
API_PORT=8080
